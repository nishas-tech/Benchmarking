{
  "title": "Local SLM Benchmarking",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "panels": [
    {
      "type": "timeseries",
      "title": "Generation Latency",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(slm_generation_latency_ms_bucket[5m])) by (le, model, temperature))",
          "legendFormat": "p95 {{model}} temp={{temperature}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Tokens Per Second",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "slm_tokens_per_second",
          "legendFormat": "{{model}} temp={{temperature}}"
        }
      ]
    },
    {
      "type": "bargauge",
      "title": "JSON Validation Success Rate",
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "slm_json_validation_success_rate",
          "legendFormat": "{{model}} temp={{temperature}}"
        }
      ]
    },
    {
      "type": "bargauge",
      "title": "Quality Score",
      "gridPos": { "x": 8, "y": 8, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "slm_quality_score",
          "legendFormat": "{{model}} temp={{temperature}}"
        }
      ]
    },
    {
      "type": "bargauge",
      "title": "Output Variance",
      "gridPos": { "x": 16, "y": 8, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "slm_output_variance_score",
          "legendFormat": "{{model}} temp={{temperature}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Memory Usage",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "slm_process_memory_mb",
          "legendFormat": "{{model}} temp={{temperature}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Retries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "increase(slm_retries_total[5m])",
          "legendFormat": "{{model}} temp={{temperature}}"
        }
      ]
    }
  ]
}

